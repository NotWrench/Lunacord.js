{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "linter": {
    "enabled": true,
    "includes": [
      "**/*",
      "!**/demo",
      "!**/apps/docs/.source/**/*",
      "!**/tests/**/*",
      "!**/dist",
      "!**/.next",
      "!**/.turbo",
      "!**/temp",
      "!**/node_modules"
    ],
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "error"
      },
      "style": {
        "useConst": "error",
        "useFilenamingConvention": "off"
      },
      "performance": {
        "noBarrelFile": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "includes": [
      "**/*",
      "!**/dist",
      "!**/.next",
      "!**/.turbo",
      "!**/temp",
      "!**/node_modules"
    ]
  },
  "extends": ["ultracite/biome/core", "ultracite/biome/vitest"]
}
