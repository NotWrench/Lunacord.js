{
  "name": "lunacord-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.12",
  "workspaces": [
    "packages/*",
    "apps/*",
    "configs/*",
    "tests"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "check": "bunx ultracite check",
    "fix": "bunx ultracite fix",
    "format": "bunx biome format --write .",
    "changeset": "bunx changeset",
    "version-packages": "bunx changeset version",
    "release": "turbo run build --filter='./packages/*' && bunx changeset publish",
    "prepare": "bunx lefthook install",
    "demo:bot": "bun --filter @lunacord/example-bot dev",
    "docs:dev": "bun --filter @lunacord/docs dev",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@changesets/cli": "^2.27.10",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bun": "latest",
    "@types/node": "^22.10.5",
    "lefthook": "^2.1.5",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "ultracite": "7.4.4"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NotWrench/Lunacord.js"
  },
  "homepage": "https://github.com/NotWrench/Lunacord.js",
  "bugs": {
    "url": "https://github.com/NotWrench/Lunacord.js/issues"
  },
  "license": "MIT"
}
