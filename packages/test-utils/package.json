{
  "name": "@lunacord/test-utils",
  "version": "0.0.0",
  "private": true,
  "description": "In-memory mock Lavalink server and test helpers for Lunacord.",
  "type": "module",
  "license": "MIT",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist .turbo",
    "lint": "biome lint src",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@lunacord/core": "workspace:*"
  },
  "devDependencies": {
    "@lunacord/tsconfig": "workspace:*",
    "@types/bun": "latest",
    "typescript": "^5.7.3"
  }
}
