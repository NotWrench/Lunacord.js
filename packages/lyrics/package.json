{
  "name": "@lunacord/lyrics",
  "version": "1.0.0-alpha.0",
  "description": "Lyrics provider layer (Lyrics.ovh + Genius) with caching and fallback, for Lunacord.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist .turbo",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "biome lint src",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@lunacord/core": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@lunacord/tsconfig": "workspace:*",
    "@types/bun": "latest",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NotWrench/Lunacord.js",
    "directory": "packages/lyrics"
  },
  "publishConfig": {
    "access": "public"
  }
}
