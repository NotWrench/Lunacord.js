{
  "name": "@lunacord/core",
  "version": "1.0.0-alpha.0",
  "description": "Builder-first Lavalink v4 client for Bun and Node.js. Nodes, players, queues, filters, lyrics, plugins, cache — all with a strictly-typed API.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./builders": {
      "types": "./dist/builders/index.d.ts",
      "import": "./dist/builders/index.js"
    },
    "./cache": {
      "types": "./dist/cache/index.d.ts",
      "import": "./dist/cache/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/schemas/index.js"
    },
    "./transports": {
      "types": "./dist/transports/index.d.ts",
      "import": "./dist/transports/index.js"
    },
    "./domain": {
      "types": "./dist/domain/index.d.ts",
      "import": "./dist/domain/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist .turbo",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "biome lint src",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@lunacord/tsconfig": "workspace:*",
    "@types/bun": "latest",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20.0.0"
  },
  "keywords": [
    "lavalink",
    "lavalink-v4",
    "discord",
    "music",
    "bun",
    "typescript",
    "audio"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/NotWrench/Lunacord.js",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  }
}
