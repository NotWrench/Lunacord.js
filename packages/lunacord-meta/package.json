{
  "name": "lunacord.js",
  "version": "1.0.0-alpha.0",
  "description": "[DEPRECATED meta-package] Re-exports @lunacord/core for backwards compatibility. Please migrate to @lunacord/core + @lunacord/discordjs.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist .turbo",
    "lint": "biome lint src",
    "typecheck": "tsc --noEmit",
    "test": "echo 'meta-package re-exports @lunacord/core — see core test suite'"
  },
  "dependencies": {
    "@lunacord/core": "workspace:*"
  },
  "devDependencies": {
    "@lunacord/tsconfig": "workspace:*",
    "typescript": "^5.7.3"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NotWrench/Lunacord.js",
    "directory": "packages/lunacord-meta"
  },
  "publishConfig": {
    "access": "public"
  }
}
