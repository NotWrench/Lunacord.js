DISCORD_TOKEN=your-discord-bot-token
LAVALINK_HOST=localhost
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_SECURE=false

# Optional. When set, slash commands are registered to this guild (instant).
# Leave unset to publish globally (~1h rollout).
# INSTALL_GUILD_ID=123456789012345678

# Optional. Enables post-restart player rehydrate via Redis.
# REDIS_URL=redis://localhost:6379

# Optional. Enables Genius lyrics fallback (LyricsOvh is always on).
# GENIUS_CLIENT_ID=
# GENIUS_CLIENT_SECRET=
# GENIUS_ACCESS_TOKEN=
