{
  "extends": "@lunacord/tsconfig/app.json",
  "compilerOptions": {
    "types": ["node", "react", "react-dom"],
    "lib": ["DOM", "DOM.Iterable", "ES2023"],
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@/.source": ["./.source/index.ts"]
    },
    "allowJs": true
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next", "out", ".source"]
}
